<?xml version="1.0" encoding="utf-8"?>
<!--
  Local-first guarantee (README hard rule: data stays on the device unless the
  user explicitly exports it). Exclude all app data from both cloud backup and
  device-to-device transfer so the Room database and files never leave the phone
  through a system path.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
